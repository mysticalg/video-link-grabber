{
  "manifest_version": 3,
  "name": "Video Link Grabber",
  "version": "1.1.0",
  "description": "Scans the current tab for video file links, stream manifests, and poster images. Does not bypass DRM.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "Find videos",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  }
}
